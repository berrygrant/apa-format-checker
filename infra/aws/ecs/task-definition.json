{
  "family": "thesis-apa-formatter",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::723173543836:role/ecsTaskExecutionRole-thesis-apa-formatter",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "thesis-apa-formatter",
      "image": "723173543836.dkr.ecr.us-east-1.amazonaws.com/thesis-apa-formatter:bootstrap",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3001,
          "hostPort": 3001,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3001"
        },
        {
          "name": "OPENAI_MODEL",
          "value": "gpt-5-mini"
        },
        {
          "name": "MAX_UPLOAD_BYTES",
          "value": "3145728"
        },
        {
          "name": "JOB_TTL_MS",
          "value": "3600000"
        },
        {
          "name": "APP_AUTH_HOST",
          "value": "apa.lingviz.com"
        }
      ],
      "secrets": [
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:723173543836:secret:prod/apa-format-checker-nhpYMl"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "node -e \"fetch('http://127.0.0.1:3001/api/health').then((res) => process.exit(res.ok ? 0 : 1)).catch(() => process.exit(1))\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-create-group": "true",
          "awslogs-group": "/ecs/thesis-apa-formatter",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
